{
  "name": "@dallincreates/boardgame-devkit",
  "version": "1.0.5",
  "description": "Development tools and utilities for dallinking boardgames",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
