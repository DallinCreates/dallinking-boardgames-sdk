{
  "name": "dallinking-boardgames-sdk",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "dallinking-boardgames-sdk",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@dallinking/boardgame-client": {
      "resolved": "packages/client",
      "link": true
    },
    "node_modules/@dallinking/boardgame-devkit": {
      "resolved": "packages/devkit",
      "link": true
    },
    "node_modules/@dallinking/boardgame-server": {
      "resolved": "packages/server",
      "link": true
    },
    "node_modules/create-dallinking-boardgame": {
      "resolved": "packages/create-dallinking-boardgame",
      "link": true
    },
    "packages/client": {
      "name": "@dallinking/boardgame-client",
      "version": "0.0.1",
      "license": "MIT",
      "dependencies": {
        "@dallinking/boardgame-server": "*"
      },
      "devDependencies": {}
    },
    "packages/create-dallinking-boardgame": {
      "version": "0.0.1",
      "license": "MIT",
      "bin": {
        "create-dallinking-boardgame": "dist/cli.cjs"
      },
      "devDependencies": {}
    },
    "packages/devkit": {
      "name": "@dallinking/boardgame-devkit",
      "version": "0.0.1",
      "license": "MIT",
      "bin": {
        "boardgame-devkit": "dist/cli.cjs"
      },
      "devDependencies": {}
    },
    "packages/server": {
      "name": "@dallinking/boardgame-server",
      "version": "0.0.1",
      "license": "MIT",
      "devDependencies": {}
    }
  }
}
